# Copie este arquivo para ".env" e preencha com seus dados reais

# Supabase (Project Settings > API)
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_ANON_KEY=sua-anon-key-aqui
SUPABASE_SERVICE_KEY=sua-service-role-key-aqui

# Football-Data.org (crie gratuitamente em https://www.football-data.org/client/register)
FOOTBALL_DATA_TOKEN=seu-token-aqui

# Código da competição a coletar (ex: BSA = Brasileirão, PL = Premier League)
COMPETITION_CODE=BSA

# TheSportsDB (chave "3" é a pública de teste, funciona mas é limitada)
# Assinatura paga: https://www.patreon.com/thesportsdb
THESPORTSDB_KEY=3
THESPORTSDB_LEAGUE_ID=4351
THESPORTSDB_SEASON=2025-2026

PORT=3001
